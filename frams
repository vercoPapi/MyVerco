local function CreateButton(text, callback)
    local Button = Instance.new("TextButton")
    Button.Name = text .. "Btn"
    Button.Parent = Container
    Button.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Button.Size = UDim2.new(1, 0, 0, 35)
    Button.Font = Enum.Font.SourceSans
    Button.Text = text
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 16
    
    local BStroke = Instance.new("UIStroke")
    BStroke.Parent = Button
    BStroke.Color = Color3.fromRGB(0, 80, 200)
    BStroke.Thickness = 1

    Button.MouseButton1Click:Connect(callback)
end

local function CreateToggle(text, callback)
    local Tgl = Instance.new("TextButton")
    local state = false
    Tgl.Name = text .. "Tgl"
    Tgl.Parent = Container
    Tgl.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Tgl.Size = UDim2.new(1, 0, 0, 35)
    Tgl.Font = Enum.Font.SourceSans
    Tgl.Text = text .. ": OFF"
    Tgl.TextColor3 = Color3.fromRGB(255, 0, 0)
    Tgl.TextSize = 16

    local TStroke = Instance.new("UIStroke")
    TStroke.Parent = Tgl
    TStroke.Color = Color3.fromRGB(0, 80, 200)
    TStroke.Thickness = 1

    Tgl.MouseButton1Click:Connect(function()
        state = not state
        Tgl.Text = text .. (state and ": ON" or ": OFF")
        Tgl.TextColor3 = state and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
        callback(state)
    end)
end

CreateToggle("Auto Farm", function(v)
    _G.VercoFarm = v
    while _G.VercoFarm do
        task.wait(1)
        print("VERCO Farming...")
    end
end)

CreateButton("Speed Hack (100)", function()
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 100
end)

CreateButton("Infinite Jump", function()
    game:GetService("UserInputService").JumpRequest:Connect(function()
        game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end)
end)

CreateButton("Destroy VERCO", function()
    VERCO_GUI:Destroy()
    getgenv().VERCO_LOADED = false
end)

